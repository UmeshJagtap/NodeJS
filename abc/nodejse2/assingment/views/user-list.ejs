<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Users</title>
    <style>
      .user-container {
        padding: 1rem;
        margin: 1rem;
        border: 2px solid red;
      }
      .profile-image {
        height: 5rem;
      }
    </style>
  </head>
  <body>
    <% if (name) { %>
    <h2>Welcome <%=name%>, to our users page.</h2>
    <% } %>

    <p>Users</p>

    <!-- <ul>
      <% users.forEach((user)=>{%>
      <li><%=user.name%></li>
      <li><%=user.password%></li>
      <li><%=user.email%></li>
      <li><%=user.image%></li>
      <%});%>
    </ul> -->

    <% users.forEach((user)=>{%>
    <div class="user-container">
      <!-- Profile Photo -->
      <!-- <p><%=user.imageurl%></p> -->
      <img
        src="<%= user.imageurl %>"
        alt="Profile image"
        class="profile-image"
      />

      <h3><%=user.name%></h3>

      <p><%=user.email%></p>

      <p><%=user.birthhdate%></p>

      <p><%=user.role%></p>
    </div>
    <%});%>
  </body>
</html>

<!-- 
. Name
. Email
. Birthdate
. Profile Photo
. Role (SuperAdmin / ViewAdmin / EditAdmin) 
-->

