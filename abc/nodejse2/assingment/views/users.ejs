<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Users</title>
    <style>
      .user-container {
        padding: 1rem;
        margin: 1rem;
        border: 2px solid red;
      }
    </style>
  </head>
  <body>
    <% if (name) { %>
    <h2>Welcome <%=name%>, to our users page.</h2>
    <% } %>

    <p>Users</p>

    <!-- <ul>
      <% users.forEach((user)=>{%>
      <li><%=user.name%></li>
      <li><%=user.password%></li>
      <li><%=user.email%></li>
      <li><%=user.image%></li>
      <%});%>
    </ul> -->

    <% users.forEach((user)=>{%>
    <div class="user-container">
      <p><%=user.image%></p>
      <h3><%=user.name%></h3>
      <p><%=user.password%></p>
      <p><%=user.email%></p>
    </div>
    <%});%>
  </body>
</html>
